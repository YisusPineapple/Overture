<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Liquid Glass Orb Background (Fixed Arc & Safe Size) -->
    <path android:pathData="M 54,20 A 34,34 0 1,1 54,88 A 34,34 0 1,1 54,20 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:startX="54" android:startY="20" android:endX="54" android:endY="88" android:type="linear">
                <item android:offset="0" android:color="#40D946EF"/>
                <item android:offset="1" android:color="#10545DFF"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- The "O" Wave (Overture Core) -->
    <path android:pathData="M 54 32 C 68 32, 76 42, 76 54 C 76 66, 68 76, 54 76 C 40 76, 32 66, 32 54 C 32 42, 40 32, 54 32 Z"
        android:strokeWidth="4" android:strokeLineCap="round">
        <aapt:attr name="android:strokeColor">
            <gradient android:startX="32" android:startY="32" android:endX="76" android:endY="76" android:type="linear">
                <item android:offset="0" android:color="#D946EF"/>
                <item android:offset="0.5" android:color="#AD2A5A"/>
                <item android:offset="1" android:color="#545DFF"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Play Button -->
    <path android:pathData="M 48 44 L 66 54 L 48 64 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:startX="48" android:startY="44" android:endX="66" android:endY="64" android:type="linear">
                <item android:offset="0" android:color="#FFFFFF"/>
                <item android:offset="1" android:color="#E0E0E0"/>
            </gradient>
        </aapt:attr>
    </path>
    
    <!-- Specular Highlight -->
    <path android:pathData="M 54 32 C 40 32, 32 42, 32 54 C 32 58, 34 62, 38 65 C 36 55, 40 42, 54 36 C 62 33, 70 34, 74 38 C 72 34, 64 32, 54 32 Z"
        android:fillColor="#40FFFFFF"/>
</vector>